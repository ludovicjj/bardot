{% extends 'front/base_front.html.twig' %}

{% form_theme form 'form/theme.html.twig' %}

{% block title %}{{ page_meta_title('review_index') }}{% endblock %}

{% block meta_description %}{{ page_meta_description('review_index') }}{% endblock %}

{% block body %}
    <style>
        .rating-stars label:has(input:checked),
        .rating-stars label:has(input:checked) ~ label,
        .rating-stars label:hover,
        .rating-stars label:hover ~ label {
            color: rgb(250 204 21);
        }
    </style>

    <div class="w-full max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="text-center mb-10">
            <h1 class="font-['Bodoni_Moda',serif] font-normal uppercase tracking-wider text-5xl md:text-7xl text-gray-900 mb-4">
                {{ 'reviews.title'|trans }}
            </h1>
            <p class="text-sm md:text-lg text-gray-600 max-w-[200px] md:max-w-none mx-auto">
                {{ 'reviews.subtitle'|trans }}
            </p>
        </div>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 px-4 py-3 rounded-lg border text-sm {% if type == 'success' %}bg-green-50 border-green-300 text-green-800{% elseif type == 'error' %}bg-red-50 border-red-300 text-red-800{% else %}bg-blue-50 border-blue-300 text-blue-800{% endif %}">
                    {{ message|trans }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Review Form #}
        <section class="mb-12 bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
            <h2 class="text-xl font-semibold text-gray-900 mb-6">{{ 'reviews.form.heading'|trans }}</h2>

            {{ form_start(form, {attr: {class: 'space-y-6', novalidate: 'novalidate'}}) }}
                {# Honeypot — off-screen, hidden from real users; bots fill it and trip the silent-reject server-side #}
                <div aria-hidden="true" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">
                    {{ form_label(form.website, 'Site web') }}
                    {{ form_widget(form.website, {attr: {tabindex: -1, autocomplete: 'off'}}) }}
                </div>

                <div>
                    {{ form_label(form.pseudo, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.pseudo, {attr: {class: 'block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 focus:border-gray-900 focus:ring-1 focus:ring-gray-900 outline-none transition', placeholder: 'reviews.form.pseudo_placeholder'|trans, maxlength: 50}}) }}
                    {{ form_errors(form.pseudo) }}
                </div>

                <div>
                    {{ form_label(form.rating, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                    <div class="rating-stars inline-flex flex-row-reverse">
                        {% for i in [5, 4, 3, 2, 1] %}
                            <label class="cursor-pointer text-gray-300 transition px-1">
                                <input type="radio" name="{{ form.rating.vars.full_name }}" value="{{ i }}" class="sr-only"{% if form.rating.vars.value == i %} checked{% endif %}>
                                <svg class="w-9 h-9" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.538 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.538-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.719c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                                <span class="sr-only">{{ i }}</span>
                            </label>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.rating) }}
                    {% do form.rating.setRendered %}
                </div>

                <div>
                    {{ form_label(form.message, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-2'}}) }}
                    {{ form_widget(form.message, {attr: {class: 'block w-full rounded-lg border border-gray-300 px-4 py-3 text-gray-900 focus:border-gray-900 focus:ring-1 focus:ring-gray-900 outline-none transition resize-none', placeholder: 'reviews.form.message_placeholder'|trans, maxlength: 1000}}) }}
                    {{ form_errors(form.message) }}
                </div>

                {{ form_row(form.captcha) }}

                <div class="flex justify-end">
                    <button type="submit"
                            class="inline-flex items-center justify-center bg-gray-900 hover:bg-gray-800 text-white font-semibold px-8 py-3 rounded-lg transition-all">
                        {{ 'reviews.send'|trans }}
                    </button>
                </div>

                {% set privacyLink %}<a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="underline hover:text-gray-700">{{ 'contact.recaptcha_privacy'|trans }}</a>{% endset %}
                {% set termsLink %}<a href="https://policies.google.com/terms" target="_blank" rel="noopener" class="underline hover:text-gray-700">{{ 'contact.recaptcha_terms'|trans }}</a>{% endset %}
                <p class="text-xs text-gray-500 text-center">
                    {{ 'contact.recaptcha'|trans({'%privacy_link%': privacyLink, '%terms_link%': termsLink})|raw }}
                </p>
            {{ form_end(form) }}
        </section>

        {# Reviews listing #}
        {% if reviews is empty %}
            <div class="text-center py-20">
                <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
                </svg>
                <p class="text-gray-500">{{ 'reviews.empty'|trans }}</p>
            </div>
        {% else %}
            <div class="space-y-6">
                {% for review in reviews %}
                    <article class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
                        <div class="flex items-start justify-between gap-4 mb-3">
                            <div class="min-w-0">
                                <h2 class="text-lg font-semibold text-gray-900 truncate">{{ review.pseudo }}</h2>
                                <div class="flex items-center mt-1" aria-label="{{ review.rating }}/5">
                                    {% for i in 1..5 %}
                                        <svg class="w-5 h-5 {{ i <= review.rating ? 'text-yellow-400' : 'text-gray-200' }}"
                                             fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.538 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.538-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.719c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                        </svg>
                                    {% endfor %}
                                </div>
                            </div>
                            <time datetime="{{ review.createdAt|date('Y-m-d') }}" class="text-xs text-gray-500 shrink-0 mt-1">
                                {{ review.createdAt|date('d/m/Y') }}
                            </time>
                        </div>
                        <p class="text-gray-700 whitespace-pre-line break-words">{{ review.message }}</p>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
