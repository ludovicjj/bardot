{% extends 'admin/admin_layout.html.twig' %}

{% block title %}Avis - {{ parent() }}{% endblock %}

{% block page_title %}Avis{% endblock %}

{% block content %}
    <div class="mb-6">
        <p class="text-slate-400">Modérer les avis laissés par les visiteurs sur le livre d'or.</p>
    </div>

    {# Filter tabs #}
    {% set tabs = [
        {value: 'pending',  label: 'En attente'},
        {value: 'approved', label: 'Validés'},
        {value: 'hidden',   label: 'Masqués'},
        {value: 'all',      label: 'Tous'}
    ] %}
    <div class="mb-6 flex flex-wrap gap-2">
        {% for tab in tabs %}
            <a href="{{ path('app_admin_review_index', {status: tab.value}) }}"
               class="inline-flex items-center px-4 py-2 rounded-lg text-sm transition
               {% if currentStatus == tab.value %}bg-purple-600 text-white{% else %}bg-slate-900 border border-slate-700 text-slate-300 hover:bg-slate-800 hover:text-white{% endif %}">
                {{ tab.label }}
                <span class="ml-2 inline-flex items-center justify-center bg-slate-950/40 text-xs font-semibold px-2 py-0.5 rounded-full">{{ counts[tab.value] }}</span>
            </a>
        {% endfor %}
    </div>

    {% if reviews is empty %}
        <div class="bg-slate-900 rounded-xl p-12 border border-slate-700 text-center">
            <svg class="w-16 h-16 mx-auto text-slate-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
            <p class="text-slate-400">Aucun avis dans cette catégorie.</p>
        </div>
    {% else %}
        <div class="space-y-3">
            {% for review in reviews %}
                <article class="bg-slate-900 border border-slate-700 rounded-lg p-4">
                    <div class="flex items-start justify-between gap-4 mb-3">
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center flex-wrap gap-2 mb-2">
                                <span class="text-white font-medium">{{ review.pseudo }}</span>
                                {% if review.status == 'pending' %}
                                    <span class="px-2 py-0.5 text-xs rounded-full bg-amber-500/20 text-amber-400">En attente</span>
                                {% elseif review.status == 'approved' %}
                                    <span class="px-2 py-0.5 text-xs rounded-full bg-green-500/20 text-green-400">Validé</span>
                                {% elseif review.status == 'hidden' %}
                                    <span class="px-2 py-0.5 text-xs rounded-full bg-slate-500/20 text-slate-400">Masqué</span>
                                {% endif %}
                            </div>
                            <div class="flex items-center flex-wrap gap-2 text-xs text-slate-500">
                                <div class="flex" aria-label="{{ review.rating }}/5">
                                    {% for i in 1..5 %}
                                        <svg class="w-4 h-4 {{ i <= review.rating ? 'text-yellow-400' : 'text-slate-700' }}"
                                             fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.538 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.538-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.719c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                        </svg>
                                    {% endfor %}
                                </div>
                                <span>·</span>
                                <span>{{ review.createdAt|date('d/m/Y H:i') }}</span>
                                <span>·</span>
                                <code class="text-slate-600">{{ review.ip ?: '—' }}</code>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 shrink-0">
                            {% if review.status != 'approved' %}
                                <form method="post" action="{{ path('app_admin_review_approve', {id: review.id}) }}" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ review.id) }}">
                                    <input type="hidden" name="status" value="{{ currentStatus }}">
                                    <button type="submit"
                                            class="p-2 border border-green-900/50 rounded-md text-green-400 hover:text-green-300 hover:border-green-700 transition"
                                            title="Valider">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                        </svg>
                                    </button>
                                </form>
                            {% endif %}

                            {% if review.status == 'approved' %}
                                <form method="post" action="{{ path('app_admin_review_hide', {id: review.id}) }}" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('hide' ~ review.id) }}">
                                    <input type="hidden" name="status" value="{{ currentStatus }}">
                                    <button type="submit"
                                            class="p-2 border border-slate-600 rounded-md text-slate-400 hover:text-white hover:border-slate-400 transition"
                                            title="Masquer">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                        </svg>
                                    </button>
                                </form>
                            {% endif %}

                            <form method="post" action="{{ path('app_admin_review_delete', {id: review.id}) }}" class="inline"
                                  onsubmit="return confirm('Supprimer définitivement cet avis ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ review.id) }}">
                                <input type="hidden" name="status" value="{{ currentStatus }}">
                                <button type="submit"
                                        class="p-2 border border-red-900/50 rounded-md text-red-400 hover:text-red-300 hover:border-red-700 transition"
                                        title="Supprimer">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>

                    <p class="text-slate-300 whitespace-pre-line break-words">{{ review.message }}</p>
                </article>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
